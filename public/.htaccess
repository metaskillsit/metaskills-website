# SPA fallback — serve index.html for all routes that don't match a real file
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for an existing file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Otherwise, serve index.html (lets React Router handle the route)
  RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
  # 🚨 NEVER cache HTML (VERY IMPORTANT)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>

  # ✅ Cache assets (safe because Vite uses hash)
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|ico|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Enable compression (faster loading)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>

# Browser compatibility
FileETag None
